{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/env.d.ts",
    "src/index.css",
    "src/auth/**/*.tsx",
    "src/components/Layout/**/*.tsx",
    "src/components/LoginPage.tsx",
    "src/components/ProtectedRoute.tsx",
    "src/components/ui/AppAlertHost.tsx",
    "src/components/ui/ComboBox.tsx",
    "src/components/ui/ConfirmDialog.tsx",
    "src/components/ui/DateFieldInput.tsx",
    "src/components/ui/LoadingSpinner.tsx",
    "src/components/ui/NumericFieldInput.tsx",
    "src/components/ui/ProgramPlaceholder.tsx",
    "src/components/ui/SortableTh.tsx",
    "src/components/ui/YesNoSlicer.tsx",
    "src/lib/api.ts",
    "src/lib/auth.ts",
    "src/lib/amount.ts",
    "src/lib/date.ts",
    "src/lib/render.ts",
    "src/lib/routing.ts",
    "src/lib/sort.ts",
    "src/pages/**/*.tsx",
    "src/types/index.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
